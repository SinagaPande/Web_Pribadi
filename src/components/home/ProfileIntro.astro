---
// src/components/home/ProfileIntro.astro
import './profile-card.css';
import './profile-buttons.css';
---

<section class="intro slide-in delay-4" aria-label="Profile Introduction">
  <div class="card">
    <div class="hero">
      <img src="/Imagery/profile/foto_saya.webp" alt="Foto Jonathan Sinaga" loading="lazy" />
    </div>
    
    <div class="content">
      <h2>Jonathan Sinaga</h2>
      <p>Mahasiswa Teknik Informatika Institut Teknologi Sumatra angkatan 2023 yang sedang mengeksplorasi desain 3D serta pengembangan game.</p>
    </div>

    <div class="button-container">
      <a href="https://wa.me/6285766904446" target="_blank" rel="noopener noreferrer" class="Btn" aria-label="WhatsApp">
        <span class="iconContainer">
          <div class="logo-img logo-wa"></div>
        </span>
        <span class="BG bg-wa"></span>
      </a>
      
      <a href="https://www.instagram.com/jonathandsinaga" target="_blank" rel="noopener noreferrer" class="Btn" aria-label="Instagram">
        <span class="iconContainer">
          <div class="logo-img logo-ig"></div>
        </span>
        <span class="BG bg-ig"></span>
      </a>

      <a href="mailto:jonathan.123140153@student.itera.ad.id" target="_blank" rel="noopener noreferrer" class="Btn" aria-label="Email">
        <span class="iconContainer">
          <div class="logo-img logo-gmail"></div>
        </span>
        <span class="BG bg-gmail"></span>
      </a>
    </div>
  </div>
</section>