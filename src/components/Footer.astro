---
// src/components/Footer.astro
import './Footer.css';
---

<footer class="wave-footer">
  <svg class="waves" xmlns="http://www.w3.org/2000/svg" viewBox="0 24 150 28" preserveAspectRatio="none" shape-rendering="auto">
    <defs>
      <path id="gentle-wave" d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z" />
    </defs>
    <g class="parallax">
      <use href="#gentle-wave" x="48" y="0" fill="var(--footer)" opacity="0.7" />
      <use href="#gentle-wave" x="48" y="3" fill="var(--footer)" opacity="0.5" />
      <use href="#gentle-wave" x="48" y="5" fill="var(--footer)" opacity="0.3" />
      <use href="#gentle-wave" x="48" y="7" fill="var(--footer)" opacity="1" />
    </g>
  </svg>

  <div class="footer-content">
    Thanks for visiting ;) — Jonathan Sinaga
  </div>
</footer>