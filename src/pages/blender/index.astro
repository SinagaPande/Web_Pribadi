---
// src/pages/blender/index.astro
import MainLayout from "../../layouts/MainLayout.astro";
import PortfolioCard from "./_PortfolioCard.astro";
import { blenderProjects } from "./_blenderData";
import ModelLightbox from "./_ModelLightbox.astro";
---

<MainLayout title="3D Modeling Portfolio | Jonathan Sinaga">
  <section class="section portfolio-section" aria-labelledby="portfolio-title">
    <h2 id="portfolio-title" class="section__title">3D Modeling Portfolio</h2>
    <p class="section-description">
      Models and renders created using <strong>Blender</strong> and <strong>Cycles/Eevee</strong>
    </p>

    <div class="cards-container">
      {blenderProjects.map((project) => (
        <PortfolioCard {...project} />
      ))}
    </div>
  </section>

  <ModelLightbox />
</MainLayout>

<script>
  // Script Logika Lightbox Penuh
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.getElementById('lightbox-overlay');
    const modelViewer = document.getElementById('lightbox-model');
    const closeBtn = document.getElementById('lightbox-close');

    if (!overlay || !modelViewer || !closeBtn) return;

    // Event Buka Lightbox (Klik seluruh area Card)
    document.addEventListener('click', (e) => {
      // Pengecualian: Abaikan jika yang diklik adalah tombol Detail atau elemen tambahan di bawahnya
      // @ts-ignore
      if (e.target.closest('.toggle-button') || e.target.closest('.additional-images')) return;

      // @ts-ignore
      const card = e.target.closest('.card[data-model-src]'); 
      if (!card) return;

      const src = card.getAttribute('data-model-src');
      if (src) {
        modelViewer.setAttribute('src', src);
        overlay.classList.remove('lightbox-hidden');
        document.body.style.overflow = 'hidden'; 
        document.body.classList.add('lightbox-active'); // CSS State untuk menyembunyikan elemen UI
      }
    });

    // Fungsi Tutup Lightbox
    const closeLightbox = () => {
      overlay.classList.add('lightbox-hidden');
      document.body.classList.remove('lightbox-active');
      setTimeout(() => {
        modelViewer.removeAttribute('src'); 
      }, 300);
      document.body.style.overflow = ''; 
    };

    // Event Tutup Lightbox
    closeBtn.addEventListener('click', closeLightbox);
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeLightbox();
    });
  });
</script>

<style>
  /* === STATE: LIGHTBOX ACTIVE === */
  /* Menyembunyikan Navbar, Footer, dan animasi yang menembus saat 3D Penuh terbuka */
  :global(body.lightbox-active .navbar-wrapper),
  :global(body.lightbox-active footer),
  :global(body.lightbox-active .additional-images) {
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
  }

  /* === PORTFOLIO HEADER STYLING === */
  .portfolio-section {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-description {
    color: var(--text-secondary);
    margin-bottom: var(--space-5);
    font-size: 1.1rem;
    text-align: center;
    max-width: 600px;
  }

  .section__title {
    color: var(--text-primary);
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    text-align: center;
  }

  .section__title::after {
    content: "";
    display: block;
    width: 80px;
    height: 4px;
    background: #3b82f6; /* accent-color */
    margin: var(--space-2) auto;
    border-radius: 2px;
  }

  /* === CARD LAYOUT CONTAINER === */
  .cards-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    width: 100%;
  }
</style>