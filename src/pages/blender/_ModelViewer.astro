---
// src/pages/blender/_ModelViewer.astro
interface Props {
  src: string;
  alt: string;
}

const { src, alt } = Astro.props;
---

<div class="model-container">
  <model-viewer 
    src={src} 
    alt={alt} 
    auto-rotate 
    camera-controls 
    shadow-intensity="1"
    exposure="1"
    interaction-prompt="auto">
  </model-viewer>
</div>

<script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>

<style>
  .model-container {
    width: 100%;
    max-width: 700px;
    margin: 16px 0;
    border-radius: 12px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.05); /* Sedikit kontras untuk area 3D */
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  model-viewer {
    width: 100%;
    height: 400px;
    background-color: transparent;
    --poster-color: transparent;
  }

  @media (max-width: 768px) {
    model-viewer {
      height: 300px;
    }
  }
</style>