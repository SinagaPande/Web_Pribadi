---
// src/pages/blender/_PortfolioCard.astro
import type { BlenderProject } from './_blenderData';

type Props = BlenderProject;
const { id, title, description, mainImageSrc, mainImageAlt, modelSrc, wireframes } = Astro.props;
---

<div class="card-wrapper" id={id}>
  <div class={`card ${modelSrc ? 'has-3d' : ''}`} data-model-src={modelSrc}>
    <div class="card-content">
      
      <div class="image-container">
        <img src={mainImageSrc} alt={mainImageAlt} class="main-image" loading="lazy" />
        
        {modelSrc && (
          <>
            <model-viewer 
              class="model-preview"
              auto-rotate 
              rotation-per-second="30deg"
              interaction-prompt="none"
              shadow-intensity="1"
              exposure="1">
            </model-viewer>
            <div class="hint-badge">
              <span>&#x1F4E6; Klik untuk 3D Penuh</span>
            </div>
          </>
        )}
      </div>

      <div class="text-content">
        <h1>{title}</h1>
        <p>{description}</p>
      </div>
      
    </div>
    
    <button class="toggle-button down" aria-expanded="false">&#x25BC; Detail</button>
  </div>

  <div class="additional-images hidden">
    {wireframes.map((wf) => (
      <div class={`transition-wrapper ${wf.isSquare ? 'square' : ''}`}>
        <img src={wf.normalSrc} class="img-normal" alt={wf.normalAlt} loading="lazy" />
        <img src={wf.wireframeSrc} class="img-wireframe" alt={wf.wireframeAlt} loading="lazy" />
      </div>
    ))}
    <button class="toggle-button up" aria-label="Sembunyikan detail">&#x25B2; Tutup</button>
  </div>
</div>

<style>
  /* === CARD STYLING === */
  .card-wrapper {
    width: 100%;
    max-width: 900px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .card {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-card);
    padding: var(--space-4);
    box-shadow: var(--shadow-soft);
    width: 100%;
    min-height: 250px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: 0.3s ease;
    color: var(--text-primary);
    position: relative;
    z-index: 1; 
  }

  .card.has-3d {
    cursor: pointer; /* Memberi sinyal bahwa seluruh card bisa diklik */
  }

  .card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-hover);
    background: var(--glass-bg-hover);
  }

  .card-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex: 1;
    margin-bottom: var(--space-3);
  }

  /* === IMAGE & 3D PREVIEW LAYOUT === */
  .image-container {
    max-width: 60%;
    flex-shrink: 0;
    position: relative;
    border-radius: 12px;
  }

  .main-image {
    width: 100%;
    height: auto;
    border-radius: 12px;
    display: block;
    transition: opacity 0.5s ease;
  }

  .model-preview {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none; /* Meneruskan klik ke bawah (ke card) */
    transition: opacity 0.5s ease;
    --poster-color: transparent;
  }

  .hint-badge {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    color: #fff;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 500;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s ease;
    white-space: nowrap;
    border: 1px solid rgba(255, 255, 255, 0.2);
    z-index: 10;
  }

  /* Animasi Transisi Saat Preview Aktif */
  .card.is-previewing .main-image {
    opacity: 0;
  }
  .card.is-previewing .model-preview,
  .card.is-previewing .hint-badge {
    opacity: 1;
  }

  /* === TEXT & BUTTONS === */
  .text-content {
    flex: 1;
  }

  .text-content h1 {
    margin: 0 0 var(--space-2) 0;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .text-content p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .toggle-button {
    background: #fff;
    border: 1px solid var(--accent);
    border-radius: 999px;
    padding: 10px 24px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    color: #18181B; 
    margin-top: var(--space-2);
    transition: 0.3s ease;
    align-self: center;
    display: flex;
    align-items: center;
    gap: 6px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    position: relative;
    z-index: 2; /* Agar klik tombol tidak men-trigger card lightbox */
  }

  .toggle-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    color: #3b82f6;
    border-color: #3b82f6;
  }

  /* === HIDDEN CONTENT AREA === */
  .additional-images {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 10px; 
    z-index: 1;       
    position: relative;
    width: 96%;
    background: var(--glass-bg);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: var(--radius-card); 
    padding: 20px;
    box-shadow: var(--shadow-soft);
  }

  .hidden { display: none !important; }

  /* === SCAN/MASK ANIMATION === */
  .transition-wrapper {
    position: relative;
    width: 100%;
    max-width: 700px;
    margin: 16px 0;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    display: grid; 
    grid-template-columns: 1fr;
  }

  .transition-wrapper.square {
    aspect-ratio: 1 / 1; 
    max-width: 500px;
  }

  .transition-wrapper img {
    grid-column: 1;
    grid-row: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    margin: 0 !important;
  }

  .img-normal { z-index: 1; }
  
  .img-wireframe {
    z-index: 2;
    clip-path: inset(0 0 0 100%);
    transition: clip-path 1s ease-in-out;
  }

  .transition-wrapper.show-wireframe .img-wireframe {
    clip-path: inset(0 0 0 0%);
  }

  /* Responsiveness */
  @media (max-width: 768px) {
    .card-content { flex-direction: column; text-align: center; gap: var(--space-3); }
    .image-container { max-width: 100%; margin-bottom: var(--space-1); }
    .text-content h1 { font-size: 1.5rem; }
    .additional-images { width: 100%; margin-top: var(--space-2); border-radius: var(--radius-card); border-top: 1px solid rgba(255, 255, 255, 0.4); }
  }

  @media (max-width: 480px) {
    .card { padding: var(--space-3); }
    .text-content h1 { font-size: 1.25rem; }
  }
</style>

<script>
  // === LOGIKA INTERSECTION OBSERVER & ANIMASI DETAIL ===
  document.addEventListener("DOMContentLoaded", () => {
    
    // 1. Observer untuk Preview 3D
    const timers = new Map();
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.6 // Card harus terlihat 60%
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const card = entry.target;
        
        if (entry.isIntersecting) {
          // Jika masuk viewport, mulai timer 2 detik
          const timer = setTimeout(() => {
            const modelViewer = card.querySelector('.model-preview');
            const src = card.getAttribute('data-model-src');
            
            // Injeksi source jika belum ada agar mulai load
            if (modelViewer && src && !modelViewer.hasAttribute('src')) {
              modelViewer.setAttribute('src', src);
            }
            card.classList.add('is-previewing');
          }, 1000);
          timers.set(card, timer);
        } else {
          // Batalkan timer jika scroll lewat cepat
          if (timers.has(card)) {
            clearTimeout(timers.get(card));
            timers.delete(card);
          }
          // Kembalikan ke gambar saat keluar viewport
          card.classList.remove('is-previewing');
        }
      });
    }, observerOptions);

    // Observasi semua card yang memiliki model 3D
    document.querySelectorAll('.card[data-model-src]').forEach(card => {
      observer.observe(card);
    });

    // 2. Event Delegation untuk Tombol Detail (Sama seperti sebelumnya)
    const animationIntervals = new Map();
    document.addEventListener("click", (event) => {
      // @ts-ignore
      const btn = event.target.closest(".toggle-button");
      if (!btn) return;

      const cardWrapper = btn.closest(".card-wrapper");
      if (!cardWrapper) return;

      const additionalImages = cardWrapper.querySelector(".additional-images");
      const downButton = cardWrapper.querySelector(".toggle-button.down");

      if (!additionalImages) return;

      if (btn.classList.contains("down")) {
        additionalImages.classList.remove("hidden");
        btn.classList.add("hidden");
        btn.setAttribute("aria-expanded", "true");
        startAnimation(cardWrapper);
      } else if (btn.classList.contains("up")) {
        additionalImages.classList.add("hidden");
        if (downButton) {
          downButton.classList.remove("hidden");
          downButton.setAttribute("aria-expanded", "false");
        }
        stopAnimation(cardWrapper);
      }
    });

    function startAnimation(cardWrapper) {
      const wrappers = cardWrapper.querySelectorAll(".transition-wrapper");
      if (wrappers.length === 0) return;

      wrappers.forEach((wrapper) => wrapper.classList.toggle("show-wireframe"));
      const intervalId = setInterval(() => {
        wrappers.forEach((wrapper) => wrapper.classList.toggle("show-wireframe"));
      }, 4000);
      animationIntervals.set(cardWrapper, intervalId);
    }

    function stopAnimation(cardWrapper) {
      if (animationIntervals.has(cardWrapper)) {
        clearInterval(animationIntervals.get(cardWrapper));
        animationIntervals.delete(cardWrapper);
      }
      const wrappers = cardWrapper.querySelectorAll(".transition-wrapper");
      wrappers.forEach((wrapper) => wrapper.classList.remove("show-wireframe"));
    }
  });
</script>