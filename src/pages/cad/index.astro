---
import MainLayout from '../../layouts/MainLayout.astro';
import "./cad.css";
import { cadProjects } from './_cadData';
---

<MainLayout title="CAD Design Portfolio | Jonathan Sinaga">
  <main>
    <div style="text-align: center;">
      <h1 class="section__title title-underline-red">CAD Design Portfolio</h1>
    </div>
    <p class="section-description">
      Showcasing Mechanical & Industrial Design Projects using SolidWorks
    </p>

    <section class="carousel-section" aria-label="Featured CAD Projects">
      <button class="carousel-arrow carousel-arrow--left" id="carouselPrev" aria-label="Previous Project">
        <svg viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"></path></svg>
      </button>

      <div class="carousel-viewport">
        <div class="carousel-track" id="carouselTrack">
          {cadProjects.map((project) => (
            <div class="carousel-card" data-category={project.id}>
              <img src={project.thumbnail} alt={project.title} />
              <div class="carousel-card-title">{project.title}</div>
              <div class="carousel-card-desc">{project.desc}</div>
            </div>
          ))}
        </div>
      </div>

      <button class="carousel-arrow carousel-arrow--right" id="carouselNext" aria-label="Next Project">
        <svg viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"></path></svg>
      </button>
    </section>

    <p class="gallery-hint">Klik gambar untuk memperbesar dan melihat detail desain</p>

    <section class="gallery-section" aria-label="Project Gallery">
      <div class="gallery-masonry" id="galleryMasonry">
        
        {cadProjects.map((project) => (
          <>
            <div class="gallery-item gallery-item--drawing" data-category={project.id}>
              <img src={project.drawingSrc} alt={`${project.title} Drawing`} />
            </div>
            
            <div class="gallery-item gallery-item--features" data-category={project.id}>
              <img src={project.featuresSrc} alt={`${project.title} Features`} />
            </div>

            {project.renders.map((render) => (
              <div class="gallery-item gallery-item--render" data-category={project.id}>
                <img src={render.src} alt={render.alt} />
              </div>
            ))}
          </>
        ))}

      </div>
    </section>
  </main>
</MainLayout>

<script>
  // Script navigasi carousel tetap sama seperti yang ada di file Anda
  const carouselTrack = document.getElementById("carouselTrack");
  const carouselPrev = document.getElementById("carouselPrev");
  const carouselNext = document.getElementById("carouselNext");
  // @ts-ignore
  const carouselCards = carouselTrack ? Array.from(carouselTrack.children) : [];
  const galleryItems = Array.from(document.querySelectorAll(".gallery-item"));

  let carouselIndex = 0;

  function setActiveCard(idx) {
    carouselCards.forEach((card, i) => {
      card.classList.toggle("active", i === idx);
    });
  }

  function filterGallery(category) {
    galleryItems.forEach((item) => {
      // @ts-ignore
      const isMatch = item.dataset.category === category;

      if (isMatch) {
        item.classList.remove("fade-out", "hidden");
        item.classList.add("fade-in");
      } else {
        item.classList.remove("fade-in");
        item.classList.add("fade-out");
      }
    });
    setTimeout(() => {
      galleryItems.forEach((item) => {
        if (item.classList.contains("fade-out")) {
          item.classList.add("hidden");
        }
      });
    }, 400);
  }

  function updateCarousel(triggerGallery = true) {
    if (!carouselTrack || carouselCards.length === 0) return;
    const isMobile = window.innerWidth <= 600;
    // @ts-ignore
    const gap = parseInt(getComputedStyle(carouselTrack).gap) || 0;
    const cardWidth = carouselCards[0].getBoundingClientRect().width;
    const cardFullWidth = cardWidth + gap;
    const viewportWidth = carouselTrack.parentElement?.offsetWidth || 0;
    const maxIndex = Math.max(0, carouselCards.length - 1);

    if (carouselIndex < 0) carouselIndex = 0;
    if (carouselIndex > maxIndex) carouselIndex = maxIndex;

    let calculateValue = 0;
    if (isMobile) {
      const currentCardCenter = carouselIndex * cardFullWidth + cardWidth / 2;
      const centerScreen = viewportWidth / 2;
      calculateValue = currentCardCenter - centerScreen;
    } else {
      calculateValue = carouselIndex * cardFullWidth;
      const trackWidth = carouselCards.length * cardFullWidth;
      const maxTranslate = Math.max(0, trackWidth - viewportWidth);
      if (calculateValue > maxTranslate) calculateValue = maxTranslate;
    }

    const finalTranslateX = -calculateValue;
    carouselTrack.style.transform = `translateX(${finalTranslateX}px)`;

    setActiveCard(carouselIndex);
    if (triggerGallery) {
      // @ts-ignore
      const activeCategory = carouselCards[carouselIndex].dataset.category;
      filterGallery(activeCategory);
    }

    if (carouselPrev) {
      // @ts-ignore
      carouselPrev.disabled = carouselIndex === 0;
      carouselPrev.style.opacity = carouselIndex === 0 ? "0.3" : "1";
    }
    if (carouselNext) {
      // @ts-ignore
      carouselNext.disabled = carouselIndex === maxIndex;
      carouselNext.style.opacity = carouselIndex === maxIndex ? "0.3" : "1";
    }
  }

  if (carouselTrack) {
    if (carouselPrev) {
      carouselPrev.addEventListener("click", () => {
        carouselIndex = Math.max(0, carouselIndex - 1);
        updateCarousel();
      });
    }

    if (carouselNext) {
      carouselNext.addEventListener("click", () => {
        carouselIndex = Math.min(carouselCards.length - 1, carouselIndex + 1);
        updateCarousel();
      });
    }

    carouselCards.forEach((card, idx) => {
      card.addEventListener("click", () => {
        carouselIndex = idx;
        updateCarousel();
      });
    });
    window.addEventListener("resize", () => {
      updateCarousel(false);
    });
    setTimeout(() => {
      updateCarousel();
    }, 100);
  }

  // --- SCRIPT TAMBAHAN UNTUK LIGHTBOX (UPDATED) ---
  const clickableImages = document.querySelectorAll('.gallery-item img, .carousel-card img');
  clickableImages.forEach((img) => {
    img.style.cursor = 'zoom-in';
    
    img.addEventListener('click', (e) => {
      e.stopPropagation();
      
      if (window.openGlobalLightbox) {
        // Membersihkan nama file/alt dari kata-kata teknis dan underscore agar lebih rapi
        const cleanTitle = img.alt.replace(/Drawing|Features|Render|_/gi, ' ').replace(/\s+/g, ' ').trim() || 'CAD Project';
        
        let customSubtitle = 'SolidWorks Design';

        // Cek parent element untuk menentukan jenis gambar
        const parentItem = img.closest('.gallery-item');
        
        if (parentItem) {
          if (parentItem.classList.contains('gallery-item--render')) {
            customSubtitle = 'Rendered with SOLIDWORKS Visualize';
          } else if (parentItem.classList.contains('gallery-item--drawing')) {
            customSubtitle = 'Drawing';
          } else if (parentItem.classList.contains('gallery-item--features')) {
            customSubtitle = 'Features';
          }
        } else if (img.closest('.carousel-card')) {
          // Gambar di carousel utama juga kita anggap sebagai hasil render
          customSubtitle = 'Rendered with SOLIDWORKS Visualize';
        }
        
        window.openGlobalLightbox({
          src: img.src,
          title: cleanTitle,
          subtitle: customSubtitle
        });
      }
    });
  });
</script>