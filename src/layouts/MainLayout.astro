---
// src/layouts/MainLayout.astro
import '../styles/variables.css'; 
import '../styles/base.css';      

import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import HoloBackground from '../components/backgrounds/HoloBackground.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Lightbox from '../components/Lightbox/Lightbox.astro';

const { title } = Astro.props;
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/index.html';
---

<!DOCTYPE html>
<html lang="en" translate="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="google" content="notranslate">
  <title>{title}</title>
  
  <link rel="icon" type="image/webp" href="/Imagery/icons/INGENTI_logo.webp" />

  <script is:inline>
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        return 'dark';
      }
      return 'light';
    })();
    document.documentElement.setAttribute('data-theme', theme);
  </script>
</head>
<body>
  <HoloBackground />

  <Navbar isHome={isHome} />
  
  {isHome && <ThemeToggle variant="home" />}

  <main class={isHome ? "main--home" : ""}>
    <slot />
  </main>

  <Footer />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.15 // Animasi terpicu saat 15% bagian elemen sudah masuk layar
      };

      const scrollObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target); // Matikan pantauan agar hanya berjalan 1 kali
          }
        });
      }, observerOptions);

      // Pantau semua elemen yang memiliki class slide-in
      document.querySelectorAll('.slide-in').forEach((el) => {
        scrollObserver.observe(el);
      });
    });
  </script>
  <Lightbox />
</body>
</html>